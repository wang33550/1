{
  "name": "Synthetic Recovery Benchmark v1",
  "description": "Synthetic coding-agent recovery scenarios with deterministic expectations.",
  "scenarios": [
    {
      "id": "auth_flaky_fix",
      "description": "Recover during an auth test fix without losing the schema constraint.",
      "minTailEvents": 2,
      "events": [
        {
          "kind": "user_message",
          "payload": {
            "text": "Fix the flaky auth test without changing the database schema."
          }
        },
        {
          "kind": "decision",
          "payload": {
            "category": "constraint",
            "text": "Do not modify database schema.",
            "pinned": true
          }
        },
        {
          "kind": "file_read",
          "payload": {
            "path": "src/auth/tokens.ts",
            "startLine": 1,
            "endLine": 220
          }
        },
        {
          "kind": "command_exec",
          "payload": {
            "command": "vitest tests/auth/token-refresh.test.ts",
            "dependsOnPaths": [
              "src/auth/tokens.ts",
              "tests/auth/token-refresh.test.ts"
            ],
            "exitCode": 1,
            "summary": "1 failing test: refreshes expired sessions"
          }
        },
        {
          "kind": "plan_update",
          "payload": {
            "items": [
              {
                "id": "inspect",
                "text": "Inspect flaky auth test",
                "status": "done"
              },
              {
                "id": "patch",
                "text": "Patch token refresh logic",
                "status": "in_progress"
              },
              {
                "id": "verify",
                "text": "Run auth test suite",
                "status": "pending"
              }
            ],
            "nextAction": "Patch token refresh logic"
          }
        },
        {
          "kind": "file_write",
          "payload": {
            "path": "src/auth/tokens.ts",
            "summary": "Adjusted token refresh timing to avoid race conditions.",
            "afterHash": "hash-auth-1"
          }
        }
      ],
      "expected": {
        "nextAction": "Patch token refresh logic",
        "requiredConstraints": [
          "Do not modify database schema."
        ],
        "requiredArtifacts": [
          "Adjusted token refresh timing to avoid race conditions."
        ],
        "candidateActions": [
          {
            "actionType": "file_read",
            "path": "src/auth/tokens.ts",
            "startLine": 1,
            "endLine": 220
          },
          {
            "actionType": "command_exec",
            "command": "vitest tests/auth/token-refresh.test.ts",
            "dependsOnPaths": [
              "src/auth/tokens.ts",
              "tests/auth/token-refresh.test.ts"
            ]
          }
        ]
      }
    },
    {
      "id": "release_hotfix_deployed",
      "description": "Recover after deploying a hotfix and avoid redeploying the same build.",
      "minTailEvents": 2,
      "events": [
        {
          "kind": "user_message",
          "payload": {
            "text": "Patch the readiness check bug and avoid changing deployment manifests."
          }
        },
        {
          "kind": "decision",
          "payload": {
            "category": "constraint",
            "text": "Do not change deployment manifests.",
            "pinned": true
          }
        },
        {
          "kind": "file_write",
          "payload": {
            "path": "src/server/readiness.ts",
            "summary": "Guarded readiness check against null upstream state.",
            "afterHash": "hash-release-1"
          }
        },
        {
          "kind": "command_exec",
          "payload": {
            "command": "kubectl rollout restart deploy/api",
            "sideEffect": true,
            "summary": "Rolled out the api deployment."
          }
        },
        {
          "kind": "plan_update",
          "payload": {
            "items": [
              {
                "id": "patch",
                "text": "Patch readiness check",
                "status": "done"
              },
              {
                "id": "release-notes",
                "text": "Update release notes and notify on-call",
                "status": "in_progress"
              }
            ],
            "nextAction": "Update release notes and notify on-call"
          }
        },
        {
          "kind": "file_read",
          "payload": {
            "path": "docs/releases/current.md",
            "startLine": 1,
            "endLine": 120
          }
        }
      ],
      "expected": {
        "nextAction": "Update release notes and notify on-call",
        "requiredConstraints": [
          "Do not change deployment manifests."
        ],
        "requiredArtifacts": [
          "Rolled out the api deployment."
        ],
        "candidateActions": [
          {
            "actionType": "file_read",
            "path": "docs/releases/current.md",
            "startLine": 1,
            "endLine": 120
          }
        ],
        "sideEffectActions": [
          {
            "actionType": "command_exec",
            "command": "kubectl rollout restart deploy/api",
            "sideEffect": true
          }
        ]
      }
    },
    {
      "id": "windows_log_rotation",
      "description": "Recover a Windows-specific bugfix where the next action is only present in the archived plan.",
      "minTailEvents": 2,
      "events": [
