        "candidateActions": [
          {
            "actionType": "command_exec",
            "command": "vitest tests/api/user-snapshots.test.ts",
            "dependsOnPaths": [
              "src/api/user-serializer.ts",
              "tests/api/user-snapshots.test.ts"
            ]
          }
        ]
      }
    },
    {
      "id": "billing_backfill_complete",
